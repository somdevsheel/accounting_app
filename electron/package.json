{
  "name": "ledger-accounting",
  "productName": "Ledger",
  "version": "1.0.0",
  "description": "Local-first desktop accounting app — double-entry bookkeeping for any small business.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ledger.accounting",
    "productName": "Ledger",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!venv", "!data/*.db", "!**/__pycache__/**"]
      },
      {
        "from": "../frontend",
        "to": "frontend"
      }
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Office"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.finance"
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
