{
  "name": "accrued-accounting",
  "productName": "Accrued",
  "version": "1.0.0",
  "description": "Accrued — local-first desktop accounting software — double-entry bookkeeping for any small business.",
  "author": "Somdev Sheel <somdevsheel7@gmail.com>",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.accrued.accounting",
    "productName": "Accrued",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!venv", "!dist", "!build", "!*.spec", "!data/*.db", "!**/__pycache__/**"]
      },
      {
        "from": "../backend/dist/accrued-backend",
        "to": "backend-dist/accrued-backend"
      },
      {
        "from": "../frontend",
        "to": "frontend"
      }
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Office",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.finance",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
